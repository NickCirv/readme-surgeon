{
  "name": "readme-surgeon",
  "version": "1.0.0",
  "description": "Brutal README feedback + auto-fix. Roast any README, then make it better.",
  "type": "module",
  "bin": {
    "readme-surgeon": "./bin/surgeon.js"
  },
  "main": "./src/index.js",
  "files": [
    "bin/",
    "src/",
    "banner.svg"
  ],
  "scripts": {
    "test": "node --test",
    "start": "node bin/surgeon.js",
    "lint": "node --check src/*.js bin/surgeon.js"
  },
  "keywords": [
    "readme",
    "documentation",
    "cli",
    "ai",
    "feedback",
    "github",
    "markdown"
  ],
  "author": "NickCirv",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  }
}
